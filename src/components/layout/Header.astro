---
import { getLangFromUrl, useTranslations, localizePath, unlocalizePath } from '@i18n/utils';
import { navGroups, navCta } from '@data/nav';
import Logo from './Logo.astro';
import UtilityBar from './UtilityBar.astro';
import LanguagePicker from './LanguagePicker.astro';
import Button from '@components/ui/Button.astro';
import Icon from '@components/ui/Icon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const current = unlocalizePath(Astro.url.pathname);

const resolve = (href: string, external?: boolean) => (external ? href : localizePath(href, lang));
const isActive = (href: string, external?: boolean) =>
  !external && unlocalizePath(localizePath(href, lang)) === current;
---
<header class="header">
  <UtilityBar />
  <div class="header__main">
    <div class="container header__inner">
      <a href={localizePath('/', lang)} class="header__logo" aria-label="JBS Corp home">
        <Logo />
      </a>

      <nav class="nav" aria-label="Primary">
        <ul class="nav__list">
          {navGroups.map((group) => (
            <li class="nav__item">
              <button class="nav__trigger" aria-expanded="false" aria-haspopup="true">
                {t(group.key as any)}
                <Icon name="chevron-down" size={16} />
              </button>
              <div class="nav__dropdown">
                <ul>
                  {group.children.map((child) => (
                    <li>
                      <a
                        href={resolve(child.href, child.external)}
                        class={isActive(child.href, child.external) ? 'is-active' : ''}
                        {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                      >
                        {t(child.key as any)}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))}
        </ul>
      </nav>

      <div class="header__actions">
        <Button href={resolve(navCta.href, navCta.external)} external={navCta.external} size="sm">{t('nav.bookCta')}</Button>
      </div>

      <button class="header__burger" aria-label={t('common.menu')} aria-expanded="false" aria-controls="mobile-menu">
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile" id="mobile-menu" hidden>
    <div class="mobile__panel">
      <div class="mobile__head">
        <Logo />
        <button class="mobile__close" aria-label={t('common.close')}><Icon name="close" size={26} /></button>
      </div>
      <nav class="mobile__nav" aria-label="Mobile">
        {navGroups.map((group) => (
          <details class="mobile__group">
            <summary>{t(group.key as any)}<Icon name="chevron-down" size={18} /></summary>
            <ul>
              {group.children.map((child) => (
                <li>
                  <a href={resolve(child.href, child.external)}
                    {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                    {t(child.key as any)}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </nav>
      <div class="mobile__foot">
        <Button href={resolve(navCta.href, navCta.external)} external={navCta.external} class="mobile__cta">{t('nav.bookCta')}</Button>
        <LanguagePicker />
      </div>
    </div>
  </div>
</header>

<style>
  .header { position: sticky; top: 0; z-index: 100; }
  .header__main {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-height: var(--header-h);
  }
  .header__logo { display: inline-flex; }

  .nav { margin-left: auto; }
  .nav__list { display: flex; align-items: center; gap: var(--space-2); }
  .nav__item { position: relative; }
  .nav__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.6rem 0.85rem;
    font-weight: 600;
    font-size: var(--fs-sm);
    color: var(--ink);
    border-radius: var(--radius-md);
    transition: color var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .nav__trigger :global(svg) { transition: transform var(--dur) var(--ease); }
  .nav__item:hover .nav__trigger,
  .nav__trigger[aria-expanded='true'] { color: var(--accent); background: var(--accent-soft); }
  .nav__item:hover .nav__trigger :global(svg),
  .nav__trigger[aria-expanded='true'] :global(svg) { transform: rotate(180deg); }

  .nav__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 240px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--space-3);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease), visibility var(--dur);
  }
  .nav__item:hover .nav__dropdown,
  .nav__item:focus-within .nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav__dropdown a {
    display: block;
    padding: 0.6rem 0.85rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: var(--fs-sm);
    color: var(--ink);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .nav__dropdown a:hover { background: var(--bg-alt); color: var(--accent); }
  .nav__dropdown a.is-active { color: var(--accent); background: var(--accent-soft); }

  .header__actions { display: flex; align-items: center; }
  .header__burger { display: none; color: var(--ink); padding: 0.25rem; }

  @media (max-width: 1024px) {
    .nav, .header__actions { display: none; }
    .nav { margin-left: auto; }
    .header__burger { display: inline-flex; margin-left: auto; }
  }

  /* Mobile drawer */
  .mobile { position: fixed; inset: 0; z-index: 150; }
  .mobile::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(13, 27, 56, 0.5);
    backdrop-filter: blur(2px);
  }
  .mobile__panel {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: min(360px, 88vw);
    background: var(--surface);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    overflow-y: auto;
    box-shadow: var(--shadow-lg);
  }
  .mobile__head { display: flex; align-items: center; justify-content: space-between; }
  .mobile__close { color: var(--ink); }
  .mobile__nav { display: flex; flex-direction: column; }
  .mobile__group { border-bottom: 1px solid var(--line); }
  .mobile__group summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) 0;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }
  .mobile__group summary::-webkit-details-marker { display: none; }
  .mobile__group[open] summary :global(svg) { transform: rotate(180deg); }
  .mobile__group summary :global(svg) { transition: transform var(--dur) var(--ease); }
  .mobile__group ul { padding-bottom: var(--space-3); }
  .mobile__group a {
    display: block;
    padding: 0.55rem 0.75rem;
    color: var(--ink);
    font-weight: 500;
    border-radius: var(--radius-md);
  }
  .mobile__group a:hover { background: var(--bg-alt); color: var(--accent); }
  .mobile__foot { margin-top: auto; display: flex; flex-direction: column; gap: var(--space-4); padding-top: var(--space-4); }
  .mobile__cta { width: 100%; }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.header__burger');
  const drawer = document.querySelector<HTMLElement>('#mobile-menu');
  const closeBtn = document.querySelector<HTMLButtonElement>('.mobile__close');

  const open = () => {
    if (!drawer || !burger) return;
    drawer.hidden = false;
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    if (!drawer || !burger) return;
    drawer.hidden = true;
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  burger?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  drawer?.addEventListener('click', (e) => {
    if (e.target === drawer) close();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.hidden) close();
  });
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));

  // Desktop dropdown: toggle aria-expanded for keyboard users
  document.querySelectorAll<HTMLButtonElement>('.nav__trigger').forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.nav__trigger').forEach((t) => t.setAttribute('aria-expanded', 'false'));
      trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    });
  });
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.nav__item')) {
      document.querySelectorAll('.nav__trigger').forEach((t) => t.setAttribute('aria-expanded', 'false'));
    }
  });
</script>
