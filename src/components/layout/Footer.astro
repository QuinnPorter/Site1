---
import { getLangFromUrl, useTranslations, localizePath } from '@i18n/utils';
import { footerColumns } from '@data/footer';
import { SITE, OFFICES, SOCIALS } from '@data/site';
import FooterCTA from './FooterCTA.astro';
import Logo from './Logo.astro';
import Icon from '@components/ui/Icon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const resolve = (href: string, external?: boolean) => (external ? href : localizePath(href, lang));
---
<FooterCTA />
<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__about">
      <Logo variant="light" />
      <p>{t('footer.aboutBlurb')}</p>
      <div class="footer__socials">
        {SOCIALS.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.name}>
            <Icon name={s.icon} size={18} />
          </a>
        ))}
      </div>
    </div>

    {footerColumns.map((col) => (
      <div class="footer__col">
        <h3>{t(col.titleKey as any)}</h3>
        <ul>
          {col.links.map((l) => (
            <li>
              <a href={resolve(l.href, l.external)}
                {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                {t(l.key as any)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="footer__col footer__contact">
      <h3>{t('footer.contactTitle')}</h3>
      <p class="footer__contact-blurb">{t('footer.contactBlurb')}</p>
      {OFFICES.map((o) => (
        <div class="footer__office">
          <div class="footer__office-city"><Icon name="map-pin" size={15} /> {o.city}</div>
          <div>{o.street}, {o.region}</div>
          <a href={o.phoneHref}><Icon name="phone" size={14} /> {o.phone}</a>
        </div>
      ))}
    </div>
  </div>

  <div class="footer__bar">
    <div class="container footer__bar-inner">
      <span>&copy; {year} {SITE.legalName}. {t('footer.rights')}</span>
      <a href={localizePath('/privacy-policy', lang)}>{t('footer.privacy')}</a>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--dark); color: var(--on-navy-muted); border-top: 1px solid rgba(255, 255, 255, 0.08); }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    gap: var(--space-6);
    padding-block: var(--space-8);
  }
  .footer__about p { margin-top: var(--space-4); max-width: 34ch; font-size: var(--fs-sm); line-height: 1.7; }
  .footer__socials { display: flex; gap: var(--space-3); margin-top: var(--space-5); }
  .footer__socials a {
    display: grid;
    place-items: center;
    width: 38px; height: 38px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    color: var(--on-navy);
    transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .footer__socials a:hover { background: var(--accent); color: #fff; transform: translateY(-2px); }

  .footer__col h3 {
    color: #fff;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }
  .footer__col ul { display: flex; flex-direction: column; gap: 0.7rem; }
  .footer__col a { color: var(--on-navy-muted); font-size: var(--fs-sm); transition: color var(--dur) var(--ease); }
  .footer__col a:hover { color: #fff; }

  .footer__contact-blurb { font-size: var(--fs-sm); margin-bottom: var(--space-4); }
  .footer__office { font-size: var(--fs-sm); line-height: 1.6; margin-bottom: var(--space-4); }
  .footer__office-city { display: flex; align-items: center; gap: 0.4rem; color: #fff; font-weight: 600; }
  .footer__office a { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--on-navy); margin-top: 0.15rem; }
  .footer__office a:hover { color: #fff; }

  .footer__bar { border-top: 1px solid rgba(255, 255, 255, 0.1); }
  .footer__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-4);
    font-size: var(--fs-sm);
  }
  .footer__bar a { color: var(--on-navy-muted); }
  .footer__bar a:hover { color: #fff; }

  @media (max-width: 900px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__about { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__bar-inner { flex-direction: column; gap: var(--space-2); }
  }
</style>
