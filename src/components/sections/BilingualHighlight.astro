---
import { getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const copy = {
  en: {
    titleA: 'We Speak',
    titleB: 'Your Language',
    body: "Our team is bilingual in English and Spanish — and fluent in Tax. No matter your background or where you're from, you'll always feel understood and supported at JBS.",
    quote: 'La mejor compañía para hacer tus taxes',
    author: 'Jatashaly',
  },
  es: {
    titleA: 'Hablamos',
    titleB: 'Tu Idioma',
    body: 'Nuestro equipo es bilingüe en inglés y español — y experto en impuestos. Sin importar tu origen o de dónde vengas, siempre te sentirás comprendido y apoyado en JBS.',
    quote: 'La mejor compañía para hacer tus taxes',
    author: 'Jatashaly',
  },
}[lang];
---
<section class="bilingual">
  <div class="container bilingual__grid">
    <div class="bilingual__text">
      <h2>{copy.titleA} <em>{copy.titleB}</em></h2>
      <p>{copy.body}</p>
    </div>
    <figure class="bilingual__quote">
      <span class="bilingual__mark" aria-hidden="true">&ldquo;</span>
      <blockquote>
        <p>{copy.quote}</p>
      </blockquote>
      <figcaption>— {copy.author}</figcaption>
    </figure>
  </div>
</section>

<style>
  .bilingual { background: var(--surface); padding-block: var(--space-9); }
  .bilingual__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-6), 5vw, var(--space-8));
    align-items: center;
  }
  .bilingual__text h2 { font-size: var(--fs-3xl); margin: 0; }
  .bilingual__text em { font-style: italic; color: var(--accent); }
  .bilingual__text p { color: var(--muted); line-height: 1.7; margin-top: var(--space-4); max-width: 48ch; }

  .bilingual__quote {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--space-7);
    margin: 0;
  }
  .bilingual__mark {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 0.6;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-2);
  }
  .bilingual__quote blockquote { margin: 0; }
  .bilingual__quote p {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    line-height: 1.3;
    color: var(--heading);
    margin: 0;
  }
  .bilingual__quote figcaption { margin-top: var(--space-5); color: var(--muted); font-weight: 500; }

  @media (max-width: 760px) {
    .bilingual__grid { grid-template-columns: 1fr; }
  }
</style>
