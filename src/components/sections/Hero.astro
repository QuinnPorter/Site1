---
import Button from '@components/ui/Button.astro';
import Icon from '@components/ui/Icon.astro';

interface Cta {
  label: string;
  href: string;
  external?: boolean;
}
interface Stat {
  value: string;
  label: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  accent?: string;
  titleAfter?: string;
  subtitle?: string;
  lead?: string;
  primary?: Cta;
  secondary?: Cta;
  stats?: Stat[];
  variant?: 'light' | 'dark';
}
const {
  eyebrow,
  title,
  accent,
  titleAfter,
  subtitle,
  lead,
  primary,
  secondary,
  stats = [],
  variant = 'light',
} = Astro.props;
---
<section class={`hero hero--${variant}`}>
  <div class="container hero__inner">
    {eyebrow && (
      <span class="hero__eyebrow">
        <Icon name="award" size={15} /> {eyebrow}
      </span>
    )}
    <h1 class="hero__title">
      {title}{accent && <> <span class="hero__accent">{accent}</span></>}{titleAfter && <> {titleAfter}</>}
    </h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    {lead && <p class="hero__lead">{lead}</p>}
    {(primary || secondary) && (
      <div class="hero__actions">
        {primary && (
          <Button href={primary.href} external={primary.external} size="lg">{primary.label}</Button>
        )}
        {secondary && (
          <Button href={secondary.href} external={secondary.external} variant="secondary" size="lg">
            {secondary.label}
          </Button>
        )}
      </div>
    )}
    {stats.length > 0 && (
      <dl class="hero__stats">
        {stats.map((s) => (
          <div class="hero__stat">
            <dt class="hero__stat-value">{s.value}</dt>
            <dd class="hero__stat-label">{s.label}</dd>
          </div>
        ))}
      </dl>
    )}
  </div>
</section>

<style>
  .hero { background: var(--grad-wash); border-bottom: 1px solid var(--line); }
  .hero--dark { background: var(--dark); color: var(--on-navy); border-bottom: none; }

  /* Brand: headings centered where possible */
  .hero__inner {
    max-width: 880px;
    margin-inline: auto;
    padding-top: clamp(3rem, 5.4vw, 6rem);
    padding-bottom: clamp(3.3rem, 6vw, 6.65rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent);
    font-weight: 600;
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: var(--space-5);
  }
  .hero--dark .hero__eyebrow { color: var(--teal-400); }

  .hero__title { font-size: var(--fs-hero); margin: 0; }
  .hero__accent { color: var(--accent); }
  .hero--dark .hero__title { color: #fff; }
  .hero--dark .hero__accent { color: var(--teal-400); }

  /* English tagline — secondary line under the Spanish headline */
  .hero__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-xl);
    color: var(--muted);
    line-height: 1.3;
    margin: var(--space-4) 0 0;
  }
  .hero--dark .hero__subtitle { color: var(--on-navy-muted); }

  .hero__lead {
    font-size: var(--fs-lg);
    color: var(--muted);
    max-width: 60ch;
    margin: var(--space-5) auto 0;
    line-height: 1.6;
  }
  .hero--dark .hero__lead { color: var(--on-navy-muted); }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-7);
  }

  .hero__stats {
    display: flex;
    gap: clamp(var(--space-5), 4vw, var(--space-7));
    margin: var(--space-7) 0 0;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero__stat { padding-left: var(--space-5); border-left: 1px solid var(--line-strong); }
  .hero__stat:first-child { padding-left: 0; border-left: none; }
  .hero--dark .hero__stat { border-left-color: rgba(255, 255, 255, 0.18); }

  .hero__stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-2xl);
    line-height: 1;
    color: var(--heading);
  }
  .hero--dark .hero__stat-value { color: #fff; }
  .hero__stat-label { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--muted); font-weight: 500; }
  .hero--dark .hero__stat-label { color: var(--on-navy-muted); }

  @media (max-width: 560px) {
    .hero__stat { padding-left: var(--space-4); }
  }
</style>
