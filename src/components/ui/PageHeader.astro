---
interface Props {
  eyebrow?: string;
  title: string;
  accent?: string;
  lead?: string;
  align?: 'center' | 'left';
}
const { eyebrow, title, accent, lead, align = 'center' } = Astro.props;
---
<section class={`pagehead pagehead--${align}`}>
  <div class="container pagehead__inner">
    {eyebrow && <span class="pagehead__eyebrow">{eyebrow}</span>}
    <h1 class="pagehead__title">
      {title}{accent && <> <span class="pagehead__accent">{accent}</span></>}
    </h1>
    {lead && <p class="pagehead__lead">{lead}</p>}
  </div>
</section>

<style>
  .pagehead { background: var(--grad-wash); border-bottom: 1px solid var(--line); }
  .pagehead__inner {
    max-width: 820px;
    padding-block: clamp(var(--space-7), 5vw, var(--space-9));
    display: flex;
    flex-direction: column;
  }
  .pagehead--center .pagehead__inner {
    margin-inline: auto;
    align-items: center;
    text-align: center;
  }
  .pagehead__eyebrow {
    color: var(--accent);
    font-weight: 600;
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }
  .pagehead__title { font-size: var(--fs-3xl); margin: 0; }
  .pagehead__accent { color: var(--accent); }
  .pagehead__lead {
    font-size: var(--fs-lg);
    color: var(--muted);
    max-width: 62ch;
    margin: var(--space-4) 0 0;
    line-height: 1.6;
  }
  .pagehead--center .pagehead__lead { margin-inline: auto; }
</style>
