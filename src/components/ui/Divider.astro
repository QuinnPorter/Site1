---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div class={`divider ${className}`.trim()} aria-hidden="true"></div>

<style>
  .divider {
    height: 4px;
    width: 64px;
    border-radius: var(--radius-pill);
    background: var(--grad-swoosh);
  }
</style>
