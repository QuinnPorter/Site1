# Email delivery (Resend) — required for contact/assessment/careers forms
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where lead/contact submissions are delivered
CONTACT_TO_EMAIL=info@jbscorp.net
# Verified sender on your Resend domain (SPF/DKIM configured)
CONTACT_FROM_EMAIL="JBS Corp Website <noreply@jbscorp.net>"

# Cloudflare Turnstile (spam protection)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Public site URL (used for canonical/OG/sitemap)
PUBLIC_SITE_URL=https://jbscorp.net
